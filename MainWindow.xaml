<Window x:Class="ProductManufacturingSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система управления производством" 
        Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ШАПКА -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#3498DB" CornerRadius="5" 
                        Width="45" Height="45" Margin="0,0,15,0">
                    <TextBlock Text="🏭" FontSize="28" HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Система управления производством" 
                               FontSize="20" FontWeight="Bold" 
                               Foreground="#FFFFFF"/>
                    <TextBlock x:Name="UserInfoText" 
                               Text="Загрузка..." 
                               FontSize="11" 
                               Foreground="#BDC3C7"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔄 Обновить" Click="RefreshButton_Click"
                            Background="#3498DB" Foreground="White" 
                            BorderThickness="0" Padding="12,8" 
                            Margin="0,0,10,0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="🚪 Выход" Click="LogoutButton_Click"
                            Background="#E74C3C" Foreground="White" 
                            BorderThickness="0" Padding="12,8" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ОСНОВНОЕ СОДЕРЖИМОЕ - БЛОКИ ДРУГ ПОД ДРУГОМ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ProductsPanel" Margin="20" />
        </ScrollViewer>

        <!-- СТРОКА СОСТОЯНИЯ -->
        <Border Grid.Row="2" Background="#34495E" Padding="10">
            <Grid>
                <TextBlock x:Name="StatusText" Text="Готов к работе" 
                           Foreground="#FFFFFF" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TimeText" Text="" 
                           Foreground="#95A5A6" FontSize="11"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>