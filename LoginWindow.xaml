<Window x:Class="ProductManufacturingSystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Система управления производством" 
        Height="450" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#ECF0F1">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🏭 Система управления производством" 
                           FontSize="20" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Авторизация" 
                           FontSize="14" 
                           Foreground="#BDC3C7" HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">

            <TextBlock Text="👤" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин" FontWeight="Bold" Margin="0,0,0,5" Foreground="#34495E"/>
            <TextBox x:Name="UsernameBox" 
                     FontSize="14" Padding="10"
                     Margin="0,0,0,15"
                     Background="White" BorderBrush="#BDC3C7"
                     Height="40"/>

            <TextBlock Text="Пароль" FontWeight="Bold" Margin="0,0,0,5" Foreground="#34495E"/>
            <PasswordBox x:Name="PasswordBox" 
                         FontSize="14" Padding="10"
                         Margin="0,0,0,20"
                         Background="White" BorderBrush="#BDC3C7"
                         Height="40"/>

            <Button x:Name="LoginButton" 
                    Content="Войти в систему"
                    Click="LoginButton_Click"
                    Background="#3498DB" 
                    Foreground="White" 
                    FontSize="16" FontWeight="Bold"
                    Height="45" Cursor="Hand"
                    Margin="0,0,0,10"/>

            <TextBlock x:Name="StatusMessage" 
                       Text="" 
                       Foreground="#E74C3C" 
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#34495E" Padding="10">
            <TextBlock Text="© 2026 Система управления производством" 
                       Foreground="#95A5A6" FontSize="11"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>